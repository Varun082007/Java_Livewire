//Abstraction

abstract class Animal {
    abstract void sound();
}
class Dog extends Animal {

    void sound() {
        System.out.println("Dog barks");
    }
    public static void main(String[] args) {
        Dog obj = new Dog();
        obj.sound();
    }
}

//Encapsulation

class Student {
    private int age;
    public void setAge(int a) {
        age = a;
    }
    public int getAge() {
        return age;
    }

    public static void main(String[] args) {
        Student obj = new Student();
        obj.setAge(20);
        System.out.println(obj.getAge());
    }
}

